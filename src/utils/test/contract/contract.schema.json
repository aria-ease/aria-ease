{
    "$schema": "https://json-schema.org/draft-07/schema#",
    "title": "Components Accessibility Contract Schema",
    "type": "object",
    "required": ["meta", "selectors", "static", "dynamic"],
    "additionalProperties": false,

    "properties": {
        "meta": {
            "type": "object",
            "required": ["id", "version", "description", "source", "W3CName"],
            "properties": {
                "id": { "type": "string" },
                "version": { "type": "string" },
                "lastUpdated": { "type": "string" },
                "description": { "type": "string" },
                "source": {
                    "type": "object",
                    "properties": {
                        "apg": { "type": "string" },
                        "wcag": { "type": "array" }
                    }
                },
                "W3CName": { "type": "string" }
            }
        },

        "selectors": { 
            "type": "object",
            "required": ["main"],
            "description": "CSS selectors keyed by logical name. Keys vary per component.",
            "additionalProperties": { "type": "string" }
        },

        "observables": { 
            "type": "object",
            "required": ["observable", "target"],
            "description": "",
            "properties": {
                "observable": { "type": "string" },
                "target": { "type": "string" },
                "relative": { "type": "string" }
            }  
        },

        "relationships": {
            "type": "array",
            "items": {
                "type": "object",
                "required": ["type"],
                "properties": {
                    "type": { "type": "string", "enum": ["aria-reference", "contains"] },
                    "from": { "type": "string" },
                    "attribute": { "type": "string" },
                    "to": { "type": "string" },
                    "parent": { "type": "string" },
                    "child": { "type": "string" },
                    "failureMessage": { "type": "string" },
                    "level": { "type": "string", "enum": ["optional", "recommended", "required"] }
                },
                "allOf": [
                    {
                        "if": {
                            "properties": { "type": { "const": "aria-reference" } }
                        },
                        "then": {
                            "required": ["from", "attribute", "to"]
                        }
                    },
                    {
                        "if": {
                            "properties": { "type": { "const": "contains" } }
                        },
                        "then": {
                            "required": ["parent", "child"]
                        }
                    }
                ]
            }
        },

        "static": { 
            "type": "array",
            "description": "Define static assertions that can be validated against the initial HTML state of the component.",
            "items": {
                "type": "object",
                "required": ["assertions"],
                "properties": {
                    "assertions": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "required": ["target", "assertion", "failureMessage", "level"],
                            "properties": {
                                "target": { "type": "string" },
                                "assertion": { "type": "string" },
                                "attribute": { "type": "string" },
                                "expectedValue": {
                                    "oneOf": [
                                        { "type": "string" },
                                        {
                                        "type": "object",
                                        "properties": {
                                            "ref": { "type": "string" },
                                            "property": { "type": "string" },
                                            "attribute": { "type": "string" },
                                            "relativeTarget": { "type": "string" }
                                        },
                                        "required": ["ref"]
                                        }
                                    ]
                                },
                                "failureMessage": { "type": "string" },
                                "level": { "type": "string", "enum": ["optional", "recommended", "required"] }
                            }
                        }
                    }
                }
            }
        },

        "dynamic": { 
            "type": "array",
            "description": "Define dynamic assertions that can be validated against the component's behavior over time. Each item in the dynamic array represents a user interaction scenario, the action to perform, and the assertions to validate after the action.",
            "items": {
                "type": "object",
                "required": ["description", "action", "assertions"],
                "properties": {
                    "description": { "type": "string" },
                    "level": { "type": "string", "enum": ["optional", "recommended", "required"] },
                    "orientation": { "type": "string" },
                    "isMultiple": { "type": "boolean" },
                    "given": { "type": "string" },
                    "setup": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "required": ["type", "target"],
                            "properties": {
                                "type": { "type": "string" },
                                "target": { "type": "string" },
                                "key": { "type": "string" },
                                "value": { "type": "string" },
                                "relativeTarget": { "type": "string" }
                            }
                        }
                    },
                    "action": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "required": ["type", "target"],
                            "properties": {
                                "type": { "type": "string" },
                                "target": { "type": "string" },
                                "key": { "type": "string" },
                                "value": { "type": "string" },
                                "relativeTarget": { "type": "string" }
                            }
                        }
                    },
                    "assertions": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "required": ["target", "assertion", "failureMessage", "level"],
                            "properties": {
                                "target": { "type": "string" },
                                "assertion": { "type": "string" },
                                "attribute": { "type": "string" },
                                "expectedValue": {
                                    "oneOf": [
                                        { "type": "string" },
                                        {
                                            "type": "object",
                                            "properties": {
                                                "ref": { "type": "string" },
                                                "property": { "type": "string" },
                                                "attribute": { "type": "string" },
                                                "relativeTarget": { "type": "string" }
                                            },
                                            "required": ["ref"]
                                        }
                                    ]
                                },
                                "controlledBy": {
                                    "type": "object",
                                    "properties": {
                                        "target": { "type": "string" },
                                        "relativeTarget": { "type": "string" } 
                                    },
                                    "required": ["target"]
                                },
                                "relativeTarget": { "type": "string" },
                                "failureMessage": { "type": "string" },
                                "level": { "type": "string", "enum": ["optional", "recommended", "required"] }
                            }
                        }
                    }
                }
            }
        }
    }
}